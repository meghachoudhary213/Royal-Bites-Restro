# Server Configuration
PORT=5000

# MongoDB Configuration
# MONGODB_URI or MONGO_URI can be used. For local development use: mongodb://127.0.0.1:27017/royal-bites
# For production use your MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/royal-bites?retryWrites=true&w=majority

# JWT Token Configuration
JWT_SECRET=royalbites_jwt_secret_2026

# Razorpay API Credentials (for online payment processing)
# Key ID and Secret can be obtained from Razorpay Dashboard settings
RAZORPAY_KEY_ID=rzp_test_dummyId2026
RAZORPAY_KEY_SECRET=dummySecret2026

# CORS Origin Configuration
# Specify the URL of the deployed frontend static site (or '*' to allow all)
FRONTEND_URL=http://localhost:5173

# Admin Panel Password
ADMIN_PASSWORD=royalbites2026

# Support Contact Configuration
WHATSAPP_NUMBER=1234567890
