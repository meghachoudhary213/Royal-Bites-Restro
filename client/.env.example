# Royal Bites Frontend Environment Variables

# The URL of your deployed backend web service on Render (e.g. https://royal-bites-backend.onrender.com)
# The frontend code automatically appends '/api' if not present, so the root domain is sufficient.
# For local development, leave empty or set to '/api' to use the Vite proxy.
VITE_API_URL=https://royal-bites-backend.onrender.com
